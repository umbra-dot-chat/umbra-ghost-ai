# Ghost AI Agent Configuration

# Relay server URL
RELAY_URL=wss://relay.umbra.chat/ws

# Ollama API URL
OLLAMA_URL=http://localhost:11434

# LLM model name (via Ollama)
MODEL=llama3.1

# Embedding model for codebase RAG
EMBED_MODEL=nomic-embed-text

# Bot language (en | ko)
LANGUAGE=en

# Data directory for identity + database
DATA_DIR=./data

# Path to Umbra codebase for RAG indexing
CODEBASE_PATH=../../

# HTTP port for health check + webhook
HTTP_PORT=3333

# Log level (debug | info | warn | error)
LOG_LEVEL=info
